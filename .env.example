# Lovable / Vite environment variables
# Copy this file to .env (or .env.local) and adjust values.

# When "true" the dashboard serves the bundled MOCK data (currently empty).
# When "false", it fetches real data from VITE_API_BASE.
VITE_USE_MOCK=false

# Base URL of the backend that exposes /auth/* and /ea-stats.
# Authentication is now handled by the backend via cookie sessions.
VITE_API_BASE=https://EAdashboard-api.runbickers.com

# Auto-refresh interval in seconds (default 30).
VITE_REFRESH_INTERVAL_SEC=30

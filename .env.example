# Lovable / Vite environment variables
# Copy this file to .env (or .env.local) and adjust values.

# When "true" (or unset), the dashboard serves the bundled MOCK data.
# When "false", it fetches real data from VITE_API_BASE.
VITE_USE_MOCK=false

# Base URL of the backend that exposes /api/ea-stats.
# Example: https://EAdashboard-api.runbickers.com
VITE_API_BASE=https://EAdashboard-api.runbickers.com

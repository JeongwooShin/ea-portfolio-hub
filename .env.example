# Lovable / Vite environment variables
# Copy this file to .env (or .env.local) and adjust values.

# When "true" the dashboard serves the bundled MOCK data.
# When anything else (e.g. "false"), it fetches real data from VITE_API_BASE.
VITE_USE_MOCK=true

# Base URL of the backend that exposes /ea-stats.
VITE_API_BASE=https://EAdashboard-api.runbickers.com

# Auto-refresh interval in seconds (default 30).
VITE_REFRESH_INTERVAL_SEC=30

# SHA-256 hex (lowercase) of the dashboard password.
# Leave empty to disable the password gate.
# Generate: echo -n 'your-password' | shasum -a 256
VITE_DASHBOARD_PASSWORD_HASH=
